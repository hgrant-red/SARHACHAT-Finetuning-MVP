# ==========================================
# SARHAchat Environment Variables Template
# INSTRUCTIONS: Copy this file, rename it to '.env', 
# and replace the placeholder values with your own credentials.
# ==========================================

# --- 1. Inference & Application Settings (app_gradio.py / main.py) ---
# The endpoint for your vLLM server or OpenAI-compatible API
OPENAI_API_BASE="http://your-cluster-vllm-endpoint:8000/v1"
# The name of the base model or the specific LoRA adapter you want to load
MODEL_NAME="sarhachat"

# --- 2. Database & RAG Settings (nodes.py / ingest_cdc.py) ---
# CloudNativePG / PostgreSQL connection string for pgvector
DATABASE_URL="postgresql://username:password@your-db-host:5432/cdc_db"

# --- 3. Model Training & Downloading (train_lora.py / ingest_cdc.py) ---
# Required for downloading gated models like Mistral from Hugging Face
HF_TOKEN="hf_your_huggingface_token_here"

# --- 4. S3 / MinIO Storage Settings (upload_models.py) ---
# Credentials for uploading models to your cluster's object storage
S3_ENDPOINT_URL="http://your-minio-endpoint:9000"
MINIO_ACCESS_KEY="your_minio_access_key_here"
MINIO_SECRET_KEY="your_minio_secret_key_here"
S3_BUCKET_NAME="models"